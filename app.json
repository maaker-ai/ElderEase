{
  "expo": {
    "name": "ElderEase",
    "slug": "ElderEase",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "elderease",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#FFFBF0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.maaker.elderease",
      "infoPlist": {
        "UIRequiresFullScreen": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFBF0"
      },
      "package": "com.maaker.elderease",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-localization",
      "@react-native-community/datetimepicker",
      [
        "expo-splash-screen",
        {
          "ios": { "backgroundColor": "#FFFBF0" },
          "android": { "backgroundColor": "#FFFBF0" }
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ]
    ]
  }
}
